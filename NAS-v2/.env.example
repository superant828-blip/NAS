# NAS-v2 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ==================== 服务配置 ====================
NAS_HOST=0.0.0.0
NAS_PORT=8000
NAS_DEBUG=false

# ==================== 安全配置 ====================
# JWT 密钥，自动生成或手动设置
NAS_SECRET_KEY=

# ==================== 数据库配置 ====================
# 数据库类型: sqlite 或 mysql
DB_TYPE=sqlite

# SQLite 数据库路径 (相对于项目根目录)
DB_PATH=data/nas.db

# MySQL 配置 (当 DB_TYPE=mysql 时启用)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=nas
MYSQL_PASSWORD=nas123
MYSQL_DATABASE=nas_db

# MySQL Root 密码 (仅在使用 docker-compose --profile mysql 时需要)
MYSQL_ROOT_PASSWORD=root123